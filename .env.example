# Environment configuration for kenya-emergency-api.
# All variables use the KENYA_EMERGENCY_ prefix and are optional;
# sensible defaults ship with the package. Copy to `.env` to override.

# Filesystem path to the SQLite database file.
# Defaults to the snapshot database bundled inside the package.
# KENYA_EMERGENCY_DB_PATH=./data/kenya_emergency.db

# Storage backend to use. One of: "sqlite" (default) or "supabase".
# KENYA_EMERGENCY_STORAGE_ADAPTER=sqlite

# Supabase project URL. Required only when STORAGE_ADAPTER=supabase.
# KENYA_EMERGENCY_SUPABASE_URL=https://your-project.supabase.co

# Supabase API key. Required only when STORAGE_ADAPTER=supabase.
# KENYA_EMERGENCY_SUPABASE_KEY=your-supabase-key
